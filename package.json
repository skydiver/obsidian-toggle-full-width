{
  "name": "obsidian-toggle-full-width",
  "version": "1.0.0",
  "description": "Toggle any note between readable line length and full width with one click.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "author": "Martín M.",
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "repository": "https://github.com/skydiver/obsidian-toggle-full-width.git",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.19.19",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
